{{- if eq .chezmoi.os "windows" }}
# Sync agent and skill files between canonical source and tool-specific directories.
#
# Canonical agents:  ~/.agents/agents/*.md   (single source of truth)
# Claude Code:       ~/.claude/agents/*.md   (Claude-specific frontmatter)
# OpenCode:          %APPDATA%/opencode/agents/*.md (OpenCode-specific frontmatter)
# Pi subagents:      ~/.pi/agent/agents/*.md (Pi-specific frontmatter; run with /run agent-name ...)
# Skills:            ~/.agents/skills/       (symlinked into ~/.claude/skills/)
#
# Model policy:
#   - Generated Pi agents omit model by default, so Pi uses the current/default model.
#     Add pi_model: provider/model to a canonical agent, or set PI_SUBAGENT_MODEL,
#     only when you deliberately want to pin Pi subagents.
#   - Generated OpenCode agents omit opencode_model by default, so OpenCode uses its
#     configured default model (for example GPT). Set AGENT_SYNC_KEEP_TOOL_MODELS=1
#     before running chezmoi if you want to preserve opencode_model pins.
#
# The script:
#   1. Deploys canonical agents -> Claude + OpenCode + Pi (converting frontmatter)
#   2. Adds changed canonical files to chezmoi (triggers auto-commit/push)
# Only runs when monitored directories or model-policy env vars have changed.

$AgentsDir = Join-Path $env:USERPROFILE ".agents"
$CanonicalAgents = Join-Path $AgentsDir "agents"
$ClaudeAgentsDir = Join-Path $env:USERPROFILE ".claude\agents"
$OpenCodeAgentsDir = Join-Path $env:APPDATA "opencode\agents"
$PiAgentsDir = Join-Path $env:USERPROFILE ".pi\agent\agents"
$ClaudeSkillsDir = Join-Path $env:USERPROFILE ".claude\skills"
$CacheDir = Join-Path $env:LOCALAPPDATA "chezmoi"
$HashFile = Join-Path $CacheDir "agent-sync.hash"
$KeepToolModels = if ($env:AGENT_SYNC_KEEP_TOOL_MODELS) { $env:AGENT_SYNC_KEEP_TOOL_MODELS } else { "0" }
$PiSubagentModel = if ($env:PI_SUBAGENT_MODEL) { $env:PI_SUBAGENT_MODEL } else { "" }

New-Item -ItemType Directory -Force -Path $CanonicalAgents | Out-Null
New-Item -ItemType Directory -Force -Path $ClaudeAgentsDir | Out-Null
New-Item -ItemType Directory -Force -Path $OpenCodeAgentsDir | Out-Null
New-Item -ItemType Directory -Force -Path $PiAgentsDir | Out-Null
New-Item -ItemType Directory -Force -Path (Join-Path $AgentsDir "skills") | Out-Null
New-Item -ItemType Directory -Force -Path $ClaudeSkillsDir | Out-Null
New-Item -ItemType Directory -Force -Path $CacheDir | Out-Null

function Test-InheritModelValue {
    param([AllowNull()][string]$Value)
    if ([string]::IsNullOrWhiteSpace($Value)) { return $true }
    $chars = [char[]]@([char]34, [char]39)
    $v = $Value.Trim().Trim($chars).ToLowerInvariant()
    return @("inherit", "default", "current", "none", "false") -contains $v
}

function Test-KeepToolModels {
    $v = $KeepToolModels.ToLowerInvariant()
    return @("1", "true", "yes") -contains $v
}

function Get-AgentSyncHash {
    $entries = @()
    foreach ($dir in @($CanonicalAgents, $ClaudeAgentsDir, $OpenCodeAgentsDir, $PiAgentsDir)) {
        Get-ChildItem -Path $dir -Filter "*.md" -ErrorAction SilentlyContinue | ForEach-Object {
            $entries += "$($_.FullName) $($_.LastWriteTimeUtc.Ticks) $($_.Length)"
        }
    }
    $skillsPath = Join-Path $AgentsDir "skills"
    Get-ChildItem -Path $skillsPath -Recurse -File -ErrorAction SilentlyContinue | ForEach-Object {
        $entries += "$($_.FullName) $($_.LastWriteTimeUtc.Ticks) $($_.Length)"
    }
    $lockFile = Join-Path $AgentsDir ".skill-lock.json"
    if (Test-Path $lockFile) {
        $lf = Get-Item $lockFile
        $entries += "$($lf.FullName) $($lf.LastWriteTimeUtc.Ticks) $($lf.Length)"
    }
    $entries += "AGENT_SYNC_KEEP_TOOL_MODELS=$KeepToolModels"
    $entries += "PI_SUBAGENT_MODEL=$PiSubagentModel"

    $blob = ($entries | Sort-Object) -join "`n"
    $sha = [System.Security.Cryptography.SHA256]::Create()
    return [BitConverter]::ToString($sha.ComputeHash([Text.Encoding]::UTF8.GetBytes($blob))).Replace("-", "").ToLower()
}

# --- Hash check: skip if nothing changed ---
$currentHash = Get-AgentSyncHash

$previousHash = ""
if (Test-Path $HashFile) { $previousHash = (Get-Content $HashFile -Raw).Trim() }

if ($currentHash -eq $previousHash) { exit 0 }

Write-Host "Syncing agent files..."

# =============================================================================
# Helper: Convert canonical agent to Claude format
# Strips OpenCode/Pi-specific fields from YAML frontmatter, keeps Claude fields.
# =============================================================================
function ConvertTo-Claude {
    param([string]$Content)
    $lines = ($Content -replace "`r`n", "`n") -split "`n"
    $result = New-Object System.Collections.Generic.List[string]
    $inFront = $false
    $frontDone = $false
    $skipping = $false

    foreach ($line in $lines) {
        if ($line -match '^---$' -and -not $inFront -and -not $frontDone) {
            $inFront = $true
            $result.Add($line) | Out-Null
            continue
        }
        if ($line -match '^---$' -and $inFront) {
            $inFront = $false
            $frontDone = $true
            $result.Add($line) | Out-Null
            continue
        }
        if ($inFront) {
            if ($line -match '^opencode_' -or $line -match '^pi_') {
                $skipping = $true
                continue
            }
            if ($skipping -and $line -match '^  ') {
                continue
            }
            $skipping = $false
            $result.Add($line) | Out-Null
        } else {
            $result.Add($line) | Out-Null
        }
    }
    return $result -join "`n"
}

# =============================================================================
# Helper: Convert canonical agent to OpenCode format
# Strips Claude/Pi fields and renames opencode_* -> *. By default opencode_model
# is omitted so OpenCode uses its configured default model. Set
# AGENT_SYNC_KEEP_TOOL_MODELS=1 to preserve opencode_model pins.
# =============================================================================
function ConvertTo-OpenCode {
    param([string]$Content)
    $lines = ($Content -replace "`r`n", "`n") -split "`n"
    $result = New-Object System.Collections.Generic.List[string]
    $inFront = $false
    $frontDone = $false
    $skipping = $false

    foreach ($line in $lines) {
        if ($line -match '^---$' -and -not $inFront -and -not $frontDone) {
            $inFront = $true
            $result.Add($line) | Out-Null
            continue
        }
        if ($line -match '^---$' -and $inFront) {
            $inFront = $false
            $frontDone = $true
            $result.Add($line) | Out-Null
            continue
        }
        if ($inFront) {
            # Skip Claude/Pi-specific fields.
            if ($line -match '^name:' -or
                $line -match '^pi_' -or
                ($line -match '^tools:' -and $line -notmatch '^opencode_tools:') -or
                $line -match '^allowedTools:') {
                $skipping = $true
                continue
            }
            # Skip Claude model (OpenCode uses opencode_model if model pins are enabled).
            if ($line -match '^model:' -and $line -notmatch '^opencode_model:') {
                $skipping = $true
                continue
            }
            # Continuation lines for skipped fields.
            if ($skipping -and $line -match '^  ') {
                continue
            }
            $skipping = $false

            # Rename opencode_* fields.
            if ($line -match '^opencode_model:\s*(.*)$') {
                $value = $Matches[1]
                if ((Test-KeepToolModels) -and -not (Test-InheritModelValue $value)) {
                    $result.Add(($line -replace '^opencode_model:', 'model:')) | Out-Null
                }
                continue
            }
            if ($line -match '^opencode_mode:') {
                $result.Add(($line -replace '^opencode_mode:', 'mode:')) | Out-Null
                continue
            }
            if ($line -match '^opencode_tools:') {
                $result.Add(($line -replace '^opencode_tools:', 'tools:')) | Out-Null
                continue
            }
            $result.Add($line) | Out-Null
        } else {
            $result.Add($line) | Out-Null
        }
    }
    return $result -join "`n"
}

function ConvertTo-PiToolName {
    param([AllowNull()][string]$Tool)
    if ([string]::IsNullOrWhiteSpace($Tool)) { return $null }
    $chars = [char[]]@([char]34, [char]39, [char]91, [char]93, [char]44, [char]32)
    $t = $Tool.Trim().Trim($chars).ToLowerInvariant()
    switch ($t) {
        "bash" { return "bash" }
        "read" { return "read" }
        "edit" { return "edit" }
        "write" { return "write" }
        "grep" { return "grep" }
        "glob" { return "find" }
        "find" { return "find" }
        "ls" { return "ls" }
        "websearch" { return "web_search" }
        "web_search" { return "web_search" }
        "webfetch" { return "fetch_content" }
        "web_fetch" { return "fetch_content" }
        "fetch_content" { return "fetch_content" }
        "codesearch" { return "code_search" }
        "code_search" { return "code_search" }
        "getsearchcontent" { return "get_search_content" }
        "get_search_content" { return "get_search_content" }
        default {
            if ($t.StartsWith("mcp:")) { return $t }
            return $null
        }
    }
}

function Add-PiToolsFromText {
    param(
        [hashtable]$Tools,
        [string]$Text
    )
    $tmp = $Text -replace '^\s*[A-Za-z0-9_]+:\s*', ''
    $tmp = $tmp -replace '^\s*-\s*', ''
    $tmp = $tmp -replace '[\[\],"]', ' '
    $tmp = $tmp -replace "'", ' '
    foreach ($part in ($tmp -split '\s+')) {
        $mapped = ConvertTo-PiToolName $part
        if ($mapped) { $Tools[$mapped] = $true }
    }
}

function Set-PiToolFromOpenCodeLine {
    param(
        [hashtable]$OpenCodeTools,
        [string]$Line
    )
    $tmp = $Line.Trim()
    if ($tmp -match '^([A-Za-z0-9_-]+):\s*(true|false)') {
        $mapped = ConvertTo-PiToolName $Matches[1]
        if ($mapped) { $OpenCodeTools[$mapped] = ($Matches[2].ToLowerInvariant() -eq "true") }
    }
}

function Add-PiDefaultFields {
    param(
        [System.Collections.Generic.List[string]]$Result,
        [hashtable]$Tools,
        [hashtable]$OpenCodeTools,
        [AllowNull()][string]$PiModel,
        [bool]$SawSystemPromptMode,
        [bool]$SawInheritProjectContext,
        [bool]$SawInheritSkills
    )

    $modelToUse = if (-not [string]::IsNullOrWhiteSpace($PiSubagentModel)) { $PiSubagentModel } else { $PiModel }
    if (-not (Test-InheritModelValue $modelToUse)) {
        $Result.Add("model: $($modelToUse.Trim())") | Out-Null
    }
    if (-not $SawSystemPromptMode) { $Result.Add("systemPromptMode: replace") | Out-Null }
    if (-not $SawInheritProjectContext) { $Result.Add("inheritProjectContext: true") | Out-Null }
    if (-not $SawInheritSkills) { $Result.Add("inheritSkills: false") | Out-Null }

    # Safe baseline: let specialists inspect with read/bash unless disabled.
    $Tools["read"] = $true
    $Tools["bash"] = $true
    foreach ($key in @($OpenCodeTools.Keys)) {
        if ($OpenCodeTools[$key]) {
            $Tools[$key] = $true
        } else {
            $Tools.Remove($key)
        }
    }

    $ordered = @("read", "grep", "find", "ls", "bash", "edit", "write", "web_search", "code_search", "fetch_content", "get_search_content")
    $seen = @{}
    $out = @()
    foreach ($tool in $ordered) {
        $seen[$tool] = $true
        if ($Tools.ContainsKey($tool) -and $Tools[$tool]) { $out += $tool }
    }
    foreach ($tool in ($Tools.Keys | Sort-Object)) {
        if (-not $seen.ContainsKey($tool) -and $Tools[$tool]) { $out += $tool }
    }
    if ($out.Count -gt 0) {
        $Result.Add("tools: $($out -join ', ')") | Out-Null
    }
}

# =============================================================================
# Helper: Convert canonical agent to Pi subagent format
# Pi discovers user agents from ~/.pi/agent/agents/*.md and humans invoke them
# with /run agent-name task..., not @agent-name. Generated Pi agents are
# model-agnostic by default: no model field means Pi uses the current/default
# model (for example your configured GPT model).
# =============================================================================
function ConvertTo-Pi {
    param([string]$Content)
    $lines = ($Content -replace "`r`n", "`n") -split "`n"
    $result = New-Object System.Collections.Generic.List[string]
    $tools = @{}
    $openCodeTools = @{}
    $piModel = $null
    $inFront = $false
    $frontDone = $false
    $skipKind = ""
    $sawSystemPromptMode = $false
    $sawInheritProjectContext = $false
    $sawInheritSkills = $false

    foreach ($line in $lines) {
        if ($line -match '^---$' -and -not $inFront -and -not $frontDone) {
            $inFront = $true
            $result.Add($line) | Out-Null
            $result.Add("# managed by chezmoi-agent-sync; edit ~/.agents/agents/*.md") | Out-Null
            continue
        }
        if ($line -match '^---$' -and $inFront) {
            Add-PiDefaultFields -Result $result -Tools $tools -OpenCodeTools $openCodeTools -PiModel $piModel -SawSystemPromptMode $sawSystemPromptMode -SawInheritProjectContext $sawInheritProjectContext -SawInheritSkills $sawInheritSkills
            $inFront = $false
            $frontDone = $true
            $result.Add($line) | Out-Null
            continue
        }

        if ($inFront) {
            if ($skipKind) {
                if ($line -match '^\s+' -or $line -match '^\s*-') {
                    if ($skipKind -eq "tools") { Add-PiToolsFromText -Tools $tools -Text $line }
                    elseif ($skipKind -eq "opencode_tools") { Set-PiToolFromOpenCodeLine -OpenCodeTools $openCodeTools -Line $line }
                    continue
                }
                $skipKind = ""
            }

            if ($line -match '^\s*opencode_tools:') { $skipKind = "opencode_tools"; continue }
            if ($line -match '^\s*opencode_') { $skipKind = "unsupported"; continue }
            if ($line -match '^\s*pi_model:\s*(.*)$') { $piModel = $Matches[1]; continue }
            if ($line -match '^\s*pi_tools:') { Add-PiToolsFromText -Tools $tools -Text $line; $skipKind = "tools"; continue }
            if ($line -match '^\s*pi_') { $skipKind = "unsupported"; continue }
            if ($line -match '^\s*model:') { $skipKind = "unsupported"; continue }
            if ($line -match '^\s*tools:') { Add-PiToolsFromText -Tools $tools -Text $line; $skipKind = "tools"; continue }
            if ($line -match '^\s*allowedTools:') { Add-PiToolsFromText -Tools $tools -Text $line; $skipKind = "tools"; continue }
            if ($line -match '^\s*color:') { $skipKind = "unsupported"; continue }
            if ($line -match '^\s*systemPromptMode:') { $sawSystemPromptMode = $true }
            if ($line -match '^\s*inheritProjectContext:') { $sawInheritProjectContext = $true }
            if ($line -match '^\s*inheritSkills:') { $sawInheritSkills = $true }
            $result.Add($line) | Out-Null
        } else {
            $result.Add($line) | Out-Null
        }
    }
    return $result -join "`n"
}

# =============================================================================
# Deploy: canonical -> Claude + OpenCode + Pi
# =============================================================================
Get-ChildItem -Path $CanonicalAgents -Filter "*.md" -ErrorAction SilentlyContinue | ForEach-Object {
    $content = Get-Content $_.FullName -Raw -Encoding UTF8
    $name = $_.Name

    # Deploy to Claude
    $claudeContent = ConvertTo-Claude -Content $content
    $claudeContent | Set-Content (Join-Path $ClaudeAgentsDir $name) -Encoding UTF8 -NoNewline

    # Deploy to OpenCode
    $openCodeContent = ConvertTo-OpenCode -Content $content
    $openCodeContent | Set-Content (Join-Path $OpenCodeAgentsDir $name) -Encoding UTF8 -NoNewline

    # Deploy to Pi subagents (/run agent-name ...)
    $piContent = ConvertTo-Pi -Content $content
    $piContent | Set-Content (Join-Path $PiAgentsDir $name) -Encoding UTF8 -NoNewline
}

# Clean up Claude/OpenCode agents that no longer exist in canonical.
foreach ($targetDir in @($ClaudeAgentsDir, $OpenCodeAgentsDir)) {
    Get-ChildItem -Path $targetDir -Filter "*.md" -ErrorAction SilentlyContinue | ForEach-Object {
        if (-not (Test-Path (Join-Path $CanonicalAgents $_.Name))) {
            Remove-Item $_.FullName -Force
        }
    }
}

# Only remove Pi agents that this script previously generated; leave agents
# created directly through Pi's /agents manager alone.
Get-ChildItem -Path $PiAgentsDir -Filter "*.md" -ErrorAction SilentlyContinue | ForEach-Object {
    if (-not (Test-Path (Join-Path $CanonicalAgents $_.Name))) {
        $managed = Select-String -Path $_.FullName -SimpleMatch "chezmoi-agent-sync" -Quiet -ErrorAction SilentlyContinue
        if ($managed) { Remove-Item $_.FullName -Force }
    }
}

# =============================================================================
# Add canonical agents to chezmoi
# =============================================================================
Get-ChildItem -Path $CanonicalAgents -Filter "*.md" -ErrorAction SilentlyContinue | ForEach-Object {
    chezmoi add $_.FullName 2>$null
}

# =============================================================================
# Skills: symlink into ~/.claude/skills/ and add to chezmoi
# =============================================================================
$skillsPath = Join-Path $AgentsDir "skills"
Get-ChildItem -Path $skillsPath -Directory -ErrorAction SilentlyContinue | ForEach-Object {
    $target = Join-Path $ClaudeSkillsDir $_.Name
    if (-not (Test-Path $target)) {
        New-Item -ItemType SymbolicLink -Path $target -Target $_.FullName | Out-Null
    }
}

Get-ChildItem -Path $skillsPath -Recurse -File -ErrorAction SilentlyContinue | ForEach-Object {
    chezmoi add $_.FullName 2>$null
}

$lockFile = Join-Path $AgentsDir ".skill-lock.json"
if (Test-Path $lockFile) { chezmoi add $lockFile 2>$null }

# =============================================================================
# Update hash
# =============================================================================
$finalHash = Get-AgentSyncHash
$finalHash | Set-Content $HashFile -NoNewline

Write-Host "Agent sync complete. Run /reload in Pi or restart Pi, then use /agents or /run <agent> ..."
{{- end }}
