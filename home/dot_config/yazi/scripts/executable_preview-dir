#!/usr/bin/env bash
set -uo pipefail

dir=${1:-.}
[[ -d "$dir" ]] || exit 0

if command -v eza >/dev/null 2>&1; then
  eza \
    --tree \
    --level=2 \
    --color=always \
    --icons=auto \
    --group-directories-first \
    --git \
    --time-style=long-iso \
    "$dir"
else
  find "$dir" -maxdepth 2 -print | sed "s#^$dir#.#"
fi
