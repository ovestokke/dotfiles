#!/usr/bin/env bash
set -uo pipefail

file=${1:-}
[[ -f "$file" ]] || exit 0

width=${w:-120}
theme="Catppuccin Mocha"
if [[ ${t:-dark} == "light" ]]; then
  theme="Catppuccin Latte"
fi

bat_bin=""
if command -v bat >/dev/null 2>&1; then
  bat_bin=bat
elif command -v batcat >/dev/null 2>&1; then
  bat_bin=batcat
fi

bat_file() {
  if [[ -n "$bat_bin" ]]; then
    "$bat_bin" \
      --paging=never \
      --color=always \
      --style=numbers,changes \
      --wrap=never \
      --terminal-width="$width" \
      --theme="$theme" \
      "$file"
  else
    sed -n '1,400p' "$file"
  fi
}

bat_diff_file() {
  if [[ -n "$bat_bin" ]]; then
    "$bat_bin" \
      --paging=never \
      --color=always \
      --style=numbers \
      --wrap=never \
      --terminal-width="$width" \
      --theme="$theme" \
      --language=diff \
      "$file"
  else
    sed -n '1,400p' "$file"
  fi
}

case "$file" in
  *.diff|*.patch)
    bat_diff_file
    exit 0
    ;;
esac

dir=$(dirname -- "$file")
if root=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null); then
  rel=$(realpath --relative-to="$root" "$file" 2>/dev/null || printf '%s' "$file")
  status=$(git -C "$root" status --porcelain=v1 -- "$rel" 2>/dev/null || true)

  if [[ -n "$status" && ${status:0:2} != "??" ]]; then
    printf '\033[1;36m%s\033[0m\n' "git diff -- $rel"

    shown=0
    if ! git -C "$root" diff --quiet -- "$rel" 2>/dev/null; then
      if command -v delta >/dev/null 2>&1; then
        git -C "$root" diff --color=always -- "$rel" | delta --paging=never --width="$width"
      else
        git -C "$root" diff --color=always -- "$rel"
      fi
      shown=1
    fi

    if ! git -C "$root" diff --cached --quiet -- "$rel" 2>/dev/null; then
      if [[ $shown -eq 1 ]]; then
        printf '\n\033[1;35m%s\033[0m\n' 'staged changes'
      fi
      if command -v delta >/dev/null 2>&1; then
        git -C "$root" diff --cached --color=always -- "$rel" | delta --paging=never --width="$width"
      else
        git -C "$root" diff --cached --color=always -- "$rel"
      fi
      shown=1
    fi

    if [[ $shown -eq 1 ]]; then
      exit 0
    fi
  fi
fi

bat_file
