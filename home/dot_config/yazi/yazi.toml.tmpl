# Neovim-ish Yazi setup.
# macOS uses lighter preview settings because trackpads/terminals can make preview seeking laggy.

[mgr]
ratio = {{ if eq .chezmoi.os "darwin" }}[1, 4, 3]{{ else }}[1, 3, 4]{{ end }}
sort_by = "natural"
sort_sensitive = false
sort_dir_first = true
linemode = "size"
show_symlink = true
scrolloff = 8

[preview]
wrap = "no"
tab_size = 2
max_width = {{ if eq .chezmoi.os "darwin" }}900{{ else }}1200{{ end }}
max_height = {{ if eq .chezmoi.os "darwin" }}650{{ else }}900{{ end }}
image_delay = {{ if eq .chezmoi.os "darwin" }}120{{ else }}60{{ end }}
image_filter = "triangle"
image_quality = {{ if eq .chezmoi.os "darwin" }}65{{ else }}75{{ end }}

[opener]
edit = [
  { run = "nvim %s", block = true, for = "unix", desc = "Edit in Neovim" },
]

[open]
prepend_rules = [
  { mime = "text/*", use = "edit" },
  { mime = "application/{json,ndjson,javascript,x-javascript,toml,yaml,xml,sql,wine-extension-ini}", use = "edit" },
]

[plugin]
{{ if eq .chezmoi.os "darwin" -}}
# On macOS, keep all file previews on Yazi's built-in async previewers.
# Shell previewers rerun on seek and can feel sticky with mousewheel/trackpad scroll.
{{ else -}}
prepend_previewers = [
  { url = "*.diff", run = 'piper -- ~/.config/yazi/scripts/preview-code "$1"' },
  { url = "*.patch", run = 'piper -- ~/.config/yazi/scripts/preview-code "$1"' },
]
{{ end -}}
