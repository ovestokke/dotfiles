// ────────────── default (laptop/unknown) ──────────────
// Safe defaults for standard displays

// ─── Input ───
input {
    mouse {
        accel-profile "flat"
    }
}

// ─── Layout ───
layout {
    default-column-width { proportion 0.5; }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }
}
