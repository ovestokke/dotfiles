// ────────────── iris (laptop) ──────────────
// ASUS Vivobook S 14 M5406

// Idle & suspend management
// 10min: lock + screen off → 15min: suspend-then-hibernate (battery only)
// before-sleep: lock (covers lid close)
spawn-sh-at-startup "swayidle -w timeout 600 'qs -c noctalia-shell ipc call lockScreen lock' timeout 600 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors' timeout 900 'grep -q 0 /sys/class/power_supply/ACAD/online && systemctl suspend-then-hibernate' before-sleep 'qs -c noctalia-shell ipc call lockScreen lock'"

// ─── Input ───
input {
    touchpad {
        tap
        natural-scroll
        // Two-finger physical press/click acts as right-click.
        click-method "clickfinger"
        // Keep multi-finger taps conventional: 2 fingers = right, 3 fingers = middle.
        tap-button-map "left-right-middle"
    }
}
