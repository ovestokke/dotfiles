// ────────────── iris (laptop) ──────────────
// ASUS Vivobook S 14 M5406

// Idle & hibernate management
// 10min: lock + screen off → 15min: direct hibernate (battery only)
// before-sleep: lock (covers lid close)
spawn-sh-at-startup "swayidle -w timeout 600 'qs -c noctalia-shell ipc call lockScreen lock' timeout 600 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors' timeout 900 'grep -q 0 /sys/class/power_supply/ACAD/online && systemctl hibernate' before-sleep 'qs -c noctalia-shell ipc call lockScreen lock'"

// ─── Input ───
input {
    touchpad {
        tap
        natural-scroll
        // Two-finger physical press/click acts as right-click.
        click-method "clickfinger"
        // Keep multi-finger taps conventional: 2 fingers = right, 3 fingers = middle.
        tap-button-map "left-right-middle"
    }
}

output "eDP-1" {
    mode "1920x1200@60.003"
    scale 1.25
    position x=0 y=0
}

output "DP-2" {
    mode "5120x1440@165.001" // Set resolution and refresh rate
    scale 1 // No scaling (use 2 for HiDPI)
    position x=1536 y=0
    variable-refresh-rate on-demand=true
}
