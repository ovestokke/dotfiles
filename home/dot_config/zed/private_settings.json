// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "ares-cachyos",
      "username": "ove",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ove/projects/homeassistant"],
        },
      ],
    },
  ],
  "proxy": "",
  "icon_theme": "Catppuccin Frappé",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "vim_mode": false,
  "helix_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "which_key": {
    "enabled": true,
  },
  "code_lens": "on",
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "codestral": {
      "api_url": "https://codestral.mistral.ai",
    },
    "provider": "copilot",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "font_family": "MesloLGS Nerd Font Mono",
  },
  "base_keymap": "VSCode",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Frappé",
  },
}
