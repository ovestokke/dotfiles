# Ghostty Terminal Configuration
# https://ghostty.org/docs/config/reference

# Theme
{{- if eq .chezmoi.os "darwin" }}
theme = catppuccin-mocha
{{- else }}
theme = noctalia
{{- end }}
 
# Font Configuration
font-family = MesloLGS Nerd Font Mono
font-size = 14

# Window Appearance
background-opacity = 0.98
background-blur = 10
window-padding-x = 8
window-padding-y = 8

# Window Decorations
window-decoration = true
window-title-font-family = MesloLGS Nerd Font Mono

# Tab Bar Configuration (macOS uses native tabs, controlled by window-show-tab-bar)
window-show-tab-bar = auto

# Behavior
confirm-close-surface = true
copy-on-select = false
auto-update = check

# Shell (uses system default login shell)
# No shell override - inherits from system

# ── Keybindings ──
# Matches WezTerm keybinds where possible.
# Note: Ghostty has no built-in pane/split support (use a multiplexer like tmux).

# Tab management
keybind = ctrl+t=new_tab
keybind = ctrl+shift+t=toggle_tab_overview
keybind = ctrl+w=close_surface
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=goto_tab:9

# Copy/paste
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Scrollback
keybind = ctrl+u=scroll_page_fractional:-0.5
keybind = ctrl+d=scroll_page_fractional:0.5

# New window
keybind = ctrl+shift+n=new_window

# Toggle fullscreen
keybind = ctrl+shift+enter=toggle_fullscreen

# Clear scrollback
keybind = ctrl+shift+k=clear_screen

# Search
keybind = ctrl+f=start_search
